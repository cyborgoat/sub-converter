# Copy this file to .env and pick ONE input style below.

# Source type: auto (default), url, or base64
SUBSCRIPTION_SOURCE_TYPE="auto"

# Style 1: URL source
SUBSCRIPTION_URL="https://example.com/path/to/your/subscription"

# Style 2: Base64-encoded subscription text (single line)
# SUBSCRIPTION_BASE64="c3M6Ly8..."

# Optional generic source key used by auto/url/base64 modes
# SUBSCRIPTION_SOURCE="https://example.com/path/to/your/subscription"
